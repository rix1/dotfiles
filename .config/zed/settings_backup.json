// Zed settings
//
// For information on how to configure Zed, see the Zed
// documentation: https://zed.dev/docs/configuring-zed
//
// To see all of Zed's default settings without changing your
// custom settings, run `zed: open default settings` from the
// command palette (cmd-shift-p / ctrl-shift-p)
{
  "title_bar": {
    "show_branch_icon": false
  },
  "agent_ui_font_size": 12.0,
  "features": {
    "edit_prediction_provider": "zed"
  },
  "file_scan_exclusions": [
    ".yarn/"
    //
    // "*/migrations/*"
  ],
  "agent": {
    "use_modifier_to_send": true,
    "always_allow_tool_actions": true,
    "default_profile": "ask",
    "default_model": {
      "provider": "zed.dev",
      "model": "claude-haiku-4-5"
    }
  },
  "edit_predictions": {
    "mode": "subtle"
  },
  "ui_font_size": 12.0,
  "agent_buffer_font_size": 12.0,
  "buffer_font_size": 12.0,
  "vim_mode": false,
  "ui_font_family": "iA Writer Mono S",
  "buffer_font_family": "iA Writer Mono V",
  "theme": {
    "mode": "system",
    "light": "Catppuccin Latte",
    "dark": "Catppuccin Frappé"
  },
  "languages": {
    "Markdown": {
      "show_edit_predictions": false
    },
    "TSX": {
      "code_actions_on_format": {
        "source.organizeImports": true
      }
    },
    "TypeScript": {
      // "language_servers": ["deno"]
    },
    "JSON": {
      "formatter": "prettier"
    },
    "HTML": {
      "format_on_save": "off"
    },
    "Python": {
      // Use basedpyright for type checking (better than pylance for Zed)
      // and ruff for linting/formatting
      "language_servers": ["basedpyright", "ruff"],

      // "code_actions_on_format": {
      //   "source.organizeImports.ruff": true,
      //   "source.fixAll.ruff": true
      // },
      "formatter": [
        // Fix all auto-fixable lint violations
        { "code_action": "source.fixAll.ruff" },
        // Organize imports
        { "code_action": "source.organizeImports.ruff" }
      ],

      "format_on_save": "on",

      // Inlay hints for better DX
      "inlay_hints": {
        "enabled": false
      }
    }
  },

  // Configure basedpyright to match your mypy setup
  "lsp": {
    "basedpyright": {
      "settings": {
        "analysis": {
          // Diagnose all files, not just open ones
          "diagnosticMode": "workspace",

          // Match your type checking rigor
          "typeCheckingMode": "standard",

          // Show inlay hints for function arguments and return types
          "inlayHints": {
            "callArgumentNames": true,
            "functionReturnTypes": true,
            "variableTypes": true,
            "pytypeComments": true
          },

          // Exclude migrations and common non-code directories
          "exclude": [
            "**/migrations",
            "**/__pycache__",
            "**/node_modules",
            "**/.venv"
          ]
        }
      }
    },

    "ruff": {
      "initialization_options": {
        "settings": {
          // Ruff will read from your pyproject.toml, but you can override here if needed
          // Leave empty to use pyproject.toml defaults
        }
      }
    }
  }
}
