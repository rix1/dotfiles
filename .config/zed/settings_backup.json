{
  "colorize_brackets": true,
  "prettier": {
    "allowed": true,
  },
  "title_bar": {
    "show_branch_icon": false,
  },
  "agent_ui_font_size": 12.0,
  "file_scan_exclusions": [
    ".yarn/",
    "cloud/static/leaflet/",
    "cloud/static/fontawesome-full/",
  ],
  // "file_scan_inclusions": ["./scratchproject-hubspot-deal-mapping.pypad"],
  "agent": {
    "use_modifier_to_send": true,
    "always_allow_tool_actions": true,
    "default_profile": "write",
    "default_model": {
      "provider": "openai",
      "model": "gpt-5.2-codex",
    },
  },
  "edit_predictions": {
    "provider": "none",
    "mode": "subtle",
  },
  "ui_font_size": 11.0,
  "agent_buffer_font_size": 11.0,
  "buffer_font_size": 11,
  "vim_mode": false,
  "ui_font_family": "iA Writer Mono S",
  "buffer_font_family": "iA Writer Mono V",
  "theme": {
    "mode": "system",
    "light": "Catppuccin Latte",
    "dark": "Catppuccin Frappé",
  },
  "file_types": {
    "HTML": ["*.html", "*.htm", "*.jinja", "*.jinja2", "*.j2"],
  },
  "languages": {
    "Markdown": {
      "show_edit_predictions": false,
    },
    "TSX": {
      "code_actions_on_format": {
        "source.organizeImports": true,
      },
    },
    "TypeScript": {},
    "JSON": {
      "formatter": "prettier",
    },
    "HTML": {
      "format_on_save": "off",
      "language_servers": [
        "vscode-html-language-server",
        "tailwindcss-language-server",
      ],
    },
    "Python": {
      //   "language_servers": ["basedpyright", "ruff"],
      //   "format_on_save": "on",
      //   "formatter": "language_server",
      //   "code_actions_on_format": {
      //     "source.fixAll.ruff": true,
      //     "source.organizeImports.ruff": true
      //   },
      "inlay_hints": {
        "enabled": true,
      },
    },
  },
  "lsp": {
    "basedpyright": {
      "settings": {
        "analysis": {
          "diagnosticMode": "workspace",
          "typeCheckingMode": "standard",
          "inlayHints": {
            "callArgumentNames": true,
            "functionReturnTypes": true,
            "variableTypes": true,
            "pytypeComments": true,
          },
          "exclude": [
            "**/migrations",
            "**/__pycache__",
            "**/node_modules",
            "**/.venv",
          ],
        },
      },
    },
    "tailwindcss-language-server": {
      "settings": {
        "includeLanguages": {
          "jinja2": "html",
          "django-html": "html",
        },
        "classFunctions": ["cva", "cx"],
        "experimental": {
          "classRegex": ["[cls|className]\\s\\:\\=\\s\"([^\"]*)"],
        },
      },
    },
  },
}
